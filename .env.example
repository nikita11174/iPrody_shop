# Шаблон переменных окружения — скопируй в .env и заполни
# Используется при запуске через docker-compose

# RabbitMQ
RABBITMQ_USER=admin
RABBITMQ_PASS=admin
RABBITMQ_ADDRESSES=amqp://rabbitmq:5672

# Kafka
KAFKA_BOOTSTRAP_SERVERS=kafka:9092

# Межсервисные URL (внутри Docker-сети)
PAYMENT_SERVICE_URL=http://payment-service:8082
